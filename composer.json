{
    "name": "yng/yng-orm",
    "description": "A simple yng-orm",
    "keywords": ["orm","database"],      
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "Yng",
            "email": "840638148@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.1.0",
        "ext-json": "*",
        "ext-pdo": "*",
        "psr/simple-cache": "^1.0|^2.0",
        "psr/log": "^1.0|^2.0",
        "yng/yng-helper":"*"
    },
    "require-dev": {
        "phpunit/phpunit": "^7|^8|^9.5"
    },
    "autoload": {
        "psr-4": {
            "Yng\\": "src/"
        },
        "files": [
            "Stubs/load_stubs.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests"
        }
    },
    "config": {
        "sort-packages": true
    }
}
